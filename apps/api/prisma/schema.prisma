generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TitleType {
  MOVIE
  SERIES
}

enum TitleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssetKind {
  POSTER
  BACKDROP
  TRAILER
  VIDEO
  SUBTITLE
  THUMBNAIL
}

enum RatingValue {
  LIKE
  DISLIKE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(USER)
  profiles     Profile[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Profile {
  id             String          @id @default(cuid())
  userId         String
  name           String
  avatarUrl      String
  maturityRating String          @default("PG-13")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress       WatchProgress[]
  watchlist      WatchlistItem[]
  ratings        Rating[]
  events         Event[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
}

model Title {
  id            String            @id @default(cuid())
  slug          String            @unique
  name          String
  description   String
  aiSummary     String?
  type          TitleType
  status        TitleStatus       @default(PUBLISHED)
  releaseYear   Int
  runtimeMinutes Int?
  maturityRating String
  language      String            @default("English")
  cast          String[]
  moods         String[]
  tags          String[]
  popularity    Int               @default(0)
  genres        Genre[]           @relation("TitleGenres")
  assets        MediaAsset[]
  episodes      Episode[]
  progress      WatchProgress[]
  watchlist     WatchlistItem[]
  ratings       Rating[]
  events        Event[]
  embeddings    Embedding[]
  rowItems      FeaturedRowItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, popularity])
  @@index([releaseYear])
}

model Episode {
  id             String          @id @default(cuid())
  titleId        String
  seasonNumber   Int
  episodeNumber  Int
  name           String
  description    String
  runtimeMinutes Int
  videoUrl       String
  title          Title           @relation(fields: [titleId], references: [id], onDelete: Cascade)
  progress       WatchProgress[]

  @@unique([titleId, seasonNumber, episodeNumber])
}

model Genre {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  titles Title[] @relation("TitleGenres")
}

model MediaAsset {
  id       String    @id @default(cuid())
  titleId  String
  kind     AssetKind
  url      String
  altText  String?
  title    Title     @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@index([titleId, kind])
}

model WatchProgress {
  id              String   @id @default(cuid())
  profileId       String
  titleId         String
  episodeId       String?
  positionSeconds Int      @default(0)
  durationSeconds Int      @default(0)
  completed       Boolean  @default(false)
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title           Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  episode         Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([profileId, titleId])
  @@index([profileId, updatedAt])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  profileId String
  titleId   String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([profileId, titleId])
  @@index([profileId, createdAt])
}

model Rating {
  id        String      @id @default(cuid())
  profileId String
  titleId   String
  value     RatingValue
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     Title       @relation(fields: [titleId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([profileId, titleId])
}

model Event {
  id        String   @id @default(cuid())
  profileId String
  titleId   String?
  type      String
  metadata  Json?
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     Title?   @relation(fields: [titleId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([profileId, type, createdAt])
}

model Embedding {
  id        String   @id @default(cuid())
  titleId   String
  source    String
  text      String
  vector    Json
  title     Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([titleId, source])
}

model FeaturedRow {
  id        String            @id @default(cuid())
  key       String            @unique
  label     String
  strategy  String
  position  Int               @default(0)
  active    Boolean           @default(true)
  items     FeaturedRowItem[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model FeaturedRowItem {
  rowId    String
  titleId  String
  position Int
  row      FeaturedRow @relation(fields: [rowId], references: [id], onDelete: Cascade)
  title    Title       @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@id([rowId, titleId])
  @@index([rowId, position])
}
